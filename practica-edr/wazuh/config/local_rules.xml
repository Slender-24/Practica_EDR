<!-- ============================================================
     LOCAL RULES — Regles personalitzades EDR
     Exercici 3: Alertes Wazuh per a la pràctica EDR
     ============================================================ -->
<group name="local,edr,practica">

  <!-- ==========================================================
       EXERCICI 3b — Alerta nivell 10: Procés fill d'Apache
       amb connexions sortints detectades per auditd
       ========================================================== -->

  <!-- Detecció de syscall connect() des d'apache2 (audit key: APACHE_OUTBOUND_CONN) -->
  <rule id="100001" level="10">
    <if_sid>80700</if_sid>
    <field name="audit.key">APACHE_OUTBOUND_CONN</field>
    <description>ALERTA EDR: Procés fill d'Apache2 realitzant connexió sortint sospitosa</description>
    <group>apache,outbound,suspicious</group>
    <mitre>
      <id>T1071</id>
    </mitre>
  </rule>

  <!-- Detecció de shell invocada per apache2 (audit key: APACHE_CHILD_SHELL) -->
  <rule id="100002" level="10">
    <if_sid>80700</if_sid>
    <field name="audit.key">APACHE_CHILD_SHELL</field>
    <description>ALERTA EDR CRÍTICA: Apache2 ha invocat una shell filla (possible webshell/RCE)</description>
    <group>apache,shell,critical,rce</group>
    <mitre>
      <id>T1059.004</id>
    </mitre>
  </rule>

  <!-- ==========================================================
       EXERCICI 3b — Binaris sospitosos (ncat, socat, netcat)
       Detectats per auditd (audit key: SUSPICIOUS_BINARY)
       ========================================================== -->

  <rule id="100010" level="8">
    <if_sid>80700</if_sid>
    <field name="audit.key">SUSPICIOUS_BINARY</field>
    <description>Execució de binari sospitós detectada per auditd: $(audit.exe)</description>
    <group>suspicious_binary,edr</group>
    <mitre>
      <id>T1059</id>
    </mitre>
  </rule>

  <!-- ncat específicament -->
  <rule id="100011" level="9">
    <if_sid>100010</if_sid>
    <field name="audit.exe">/usr/bin/ncat|/usr/bin/netcat|/bin/nc</field>
    <description>ALERTA: Execució de Netcat/Ncat detectada — possible reverse shell o tunneling</description>
    <group>ncat,reverse_shell,edr</group>
    <mitre>
      <id>T1095</id>
    </mitre>
  </rule>

  <!-- socat específicament -->
  <rule id="100012" level="9">
    <if_sid>100010</if_sid>
    <field name="audit.exe">/usr/bin/socat</field>
    <description>ALERTA: Execució de socat detectada — possible tunneling o reverse shell</description>
    <group>socat,reverse_shell,edr</group>
    <mitre>
      <id>T1095</id>
    </mitre>
  </rule>

  <!-- ==========================================================
       EXERCICI 3b — Shells reversos (audit key: REVERSE_SHELL)
       ========================================================== -->

  <rule id="100020" level="10">
    <if_sid>80700</if_sid>
    <field name="audit.key">REVERSE_SHELL</field>
    <description>ALERTA EDR CRÍTICA: Execució de shell interactiva (-i) detectada — possible reverse shell</description>
    <group>reverse_shell,critical,edr</group>
    <mitre>
      <id>T1059.004</id>
    </mitre>
  </rule>

  <!-- ==========================================================
       EXERCICI 3c — Brute Force SSH ampliat
       Correlació d'intents fallits consecutius
       ========================================================== -->

  <!-- 5 intents fallits en 2 minuts (freqüència alta) -->
  <rule id="100030" level="10" frequency="5" timeframe="120">
    <if_matched_sid>5716</if_matched_sid>
    <same_source_ip />
    <description>ALERTA EDR: Atac de Brute Force SSH detectat des de $(srcip) — Bloqueig automàtic activat</description>
    <group>brute_force,ssh,active_response,edr</group>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- ==========================================================
       ESCALADA DE PRIVILEGIS — Monitorització addicional
       ========================================================== -->

  <rule id="100040" level="8">
    <if_sid>80700</if_sid>
    <field name="audit.key">PRIVILEGE_ESC</field>
    <description>Possible escalada de privilegis: ús de sudo/su detectat</description>
    <group>privilege_escalation,edr</group>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

  <!-- ==========================================================
       MODIFICACIÓ DE CREDENTIALS
       ========================================================== -->

  <rule id="100050" level="9">
    <if_sid>80700</if_sid>
    <field name="audit.key">CREDENTIALS_CHANGE</field>
    <description>ALERTA: Modificació de fitxers de credencials del sistema (passwd/shadow)</description>
    <group>credentials,edr</group>
    <mitre>
      <id>T1003.008</id>
    </mitre>
  </rule>

</group>
